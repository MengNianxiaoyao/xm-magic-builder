{
	"name": "XM Language",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#variables"
		},
		{
			"include": "#special-values"
		},
		{
			"include": "#hex-values"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.number-sign.xm",
					"match": "^\\s*#.*$"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.xm",
					"begin": "\"",
					"end": "\""
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.xm",
					"match": "^(魔法管理|发包|延时|对战延时|接管对战|精灵首发|精灵切换-ID|精灵切换-位置|设置背包|使用技能|使用道具|战前准备|信息输出|变量|自定义出招|自定义魔法|出招循环体|对战循环体|判断循环体|计次循环体)\\s*="
				},
				{
					"name": "keyword.control-value.xm",
					"match": "(?<=^(延时|对战延时|设置背包|战前准备|使用(?:技能|道具)|精灵(?:首发|切换-ID|切换-位置))=).+"
				},
				{
					"name": "keyword.condition.xm",
					"match": "\\b判断真\\d*\\b"
				},
				{
					"name": "keyword.condition.xm",
					"match": "\\b判断假\\d*\\b"
				},
				{
					"name": "keyword.wild-pokemon.xm",
					"match": "^\\s*野怪操作-(对战|捕捉)\\s*="
				},
				{
					"name": "keyword.loop-head.xm",
					"match": "\\b头部\\b"
				},
				{
					"name": "keyword.loop-tail.xm",
					"match": "\\b尾部\\b"
				},
				{
					"name": "keyword.loop.xm",
					"match": "(?<=对战循环体=)(对战胜利|对战未触发)"
				},
				{
					"name": "constant.numeric.expression.xm",
					"begin": "#<",
					"end": ">#",
					"patterns": [
						{
							"name": "keyword.operator.xm",
							"match": "[*+\\-/%]"
						}
					]
				},
{
					"name": "meta.condition-params.xm",
					"begin": "\\{",
					"end": "\\}",
					"patterns": [
						{
							"name": "keyword.compare-op.xm",
							"match": "(?:十六|二)进制|小(?:于(?:等于)?)?|大(?:于(?:等于)?)?|等于|不等于"
						}
					]
				},
				{
					"name": "keyword.control-break.xm",
					"match": "\\b跳出循环\\b"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"name": "variable.other.xm",
					"match": "\\[([^\\]]+)\\]"
				}
			]
		},
		"special-values": {
			"patterns": [
				{
					"name": "constant.special.xm",
					"match": "(还原背包|撤退|全精灵恢复|压血|领取)"
				}
			]
		},
		"hex-values": {
			"patterns": [
				{
					"name": "constant.numeric.hex.xm",
					"match": "\\{[^}]+\\}"
				}
			]
		}
	},
	"scopeName": "source.xm"
}