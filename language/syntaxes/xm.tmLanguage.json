{
	"name": "XM Language",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#variables"
		},
		{
			"include": "#special-values"
		},
		{
			"include": "#hex-values"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.number-sign.xm",
					"match": "^\\s*#.*$"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.xm",
					"begin": "\"",
					"end": "\""
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.xm",
					"match": "^(魔法管理|发包|(对战)?延时|接管对战|精灵(?:首发|切换-ID|切换-位置)|设置背包|使用(?:技能|道具)|战前准备|信息输出|变量|自定义(?:出招|魔法)|(对战|判断|计次)循环体)\\s*="
				},
				{
					"name": "keyword.control-value.xm",
					"match": "(?<=^(延时|对战延时|设置背包|战前准备|使用(?:技能|道具)|精灵(?:首发|切换-ID|切换-位置))=).+"
				},
				{
					"name": "keyword.loop-if.xm",
					"match": "\\b判断(真|假)\\d*\\b"
				},
				{
					"name": "keyword.control-break.xm",
					"match": "\\b跳出循环\\b"
				},
				{
					"name": "keyword.wild-pokemon.xm",
					"match": "^\\s*野怪操作-(对战|捕捉)\\s*="
				},
				{
					"name": "keyword.loop-head.xm",
					"match": "\\b头部\\b"
				},
				{
					"name": "keyword.loop-tail.xm",
					"match": "\\b尾部\\b"
				},
				{
					"name": "keyword.loop-battle.xm",
					"match": "(对战胜利|对战未触发)(头|尾)部"
				},
				{
					"name": "constant.numeric.expression.xm",
					"begin": "#<",
					"end": ">#",
					"patterns": [
						{
							"name": "keyword.operator.xm",
							"match": "[*+\\-/%]"
						}
					]
				},
				{
					"name": "meta.condition-params.xm",
					"begin": "\\{",
					"end": "\\}",
					"patterns": [
						{
							"name": "keyword.compare-op.xm",
							"match": "[大小](?:于(?:等于)?)?|(十六|二)进制|等于|不等于"
						}
					]
				},
				{
					"name": "keyword.loop-if-andor.xm",
					"begin": "\\}|",
					"end": "|\\{",
					"patterns": [
						{
							"name": "keyword.logical-op.xm",
							"match": "(且|或)"
						}
					]
				},
				{
					"name": "constant.character.escape.xm",
					"match": "\\\\[r][n]|[\\\\r\\\\n]"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"name": "variable.other.xm",
					"match": "\\[([^\\]]+)\\]"
				}
			]
		},
		"special-values": {
			"patterns": [
				{
					"name": "constant.special.xm",
					"match": "(还原背包|撤退|全精灵恢复|压血|领取)"
				}
			]
		},
		"hex-values": {
			"patterns": [
				{
					"name": "constant.numeric.hex.xm",
					"match": "\\{[^}]+\\}"
				}
			]
		}
	},
	"scopeName": "source.xm"
}