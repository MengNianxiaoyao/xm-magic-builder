{
	"comments": {
		"lineComment": "#"
	},
	"brackets": [
		["{", "}"],
		["[", "]"],
		["(", ")"]
	],
	"autoClosingPairs": [
		{ "open": "{", "close": "}" },
		{ "open": "[", "close": "]" },
		{ "open": "(", "close": ")" },
		{ "open": "\"", "close": "\"" }
	],
	"surroundingPairs": [
		{ "open": "{", "close": "}" },
		{ "open": "[", "close": "]" },
		{ "open": "(", "close": ")" },
		{ "open": "\"", "close": "\"" }
	],
	"indentationRules": {
		"increaseIndentPattern": "^\\s*(判断循环体=(头部|判断真\\d*|判断假\\d*)|(出招循环体|对战循环体|计次循环体)=.+头部)",
		"decreaseIndentPattern": "^\\s*(判断循环体=(尾部|跳出循环)|(出招循环体|对战循环体|计次循环体)=.+尾部)"
	}
}